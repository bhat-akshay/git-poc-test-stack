{
  "disabled": false,
  "flavor": "default",
  "kind": "service",
  "metadata": {
    "labels": {
      "deliveryType": "MANUAL",
      "sidecar.istio.io/inject": "true"
    },
    "name": "new-backend"
  },
  "spec": {
    "enable_host_anti_affinity": false,
    "env": {},
    "release": {
      "build": {
        "artifactory": "gar-2",
        "name": "facetsapi"
      },
      "strategy": {
        "type": "RollingUpdate"
      }
    },
    "restart_policy": "Always",
    "runtime": {
      "autoscaling": {
        "cpu_threshold": "50",
        "max": 3,
        "min": 1
      },
      "health_checks": {
        "liveness_check_type": "None",
        "liveness_exec_command": [],
        "liveness_port": "",
        "liveness_url": "/",
        "readiness_check_type": "None",
        "readiness_exec_command": [],
        "readiness_port": "",
        "readiness_url": "/",
        "startup_check_type": "None",
        "startup_exec_command": [],
        "startup_port": "",
        "startup_url": "/"
      },
      "ports": {
        "8080": {
          "port": "8080",
          "protocol": "tcp"
        }
      },
      "size": {
        "cpu": "300m",
        "memory": "1Gi"
      }
    },
    "type": "application"
  },
  "version": "0.1"
}